# AtomAgent Configuration
# Copy this file to .env and fill in your values

# API Keys (required for respective providers)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# General Settings
ATOM_WORKSPACE=~/.atom-agents/workspaces/default
# ATOM_MODEL=deepseek-chat
# ATOM_DEBUG=false

LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=

# Feishu Gateway (optional)
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_SIGNING_SECRET=
# FEISHU_ALLOW_USER_IDS=ou_xxx,ou_yyy
# FEISHU_ALLOW_GROUP_CHATS=true
# FEISHU_DEDUP_CACHE_SIZE=1024
# FEISHU_CONNECTION_MODE=long_connection
